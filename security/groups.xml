<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="module_category_service_request"
            model="ir.module.category">

        <field name="name">Service Request</field>

    </record>


    <record id="group_service_request_employee"
            model="res.groups">

        <field name="name">Employee</field>

        <field name="category_id"
               ref="service_request_management.module_category_service_request"/>

    </record>


    <record id="group_service_request_team_lead"
            model="res.groups">

        <field name="name">Team Lead</field>

        <field name="category_id"
               ref="service_request_management.module_category_service_request"/>

        <field name="implied_ids"
               eval="[(4, ref('group_service_request_employee'))]"/>

    </record>


    <record id="group_service_request_manager"
            model="res.groups">

        <field name="name">Manager</field>

        <field name="category_id"
               ref="service_request_management.module_category_service_request"/>

        <field name="implied_ids"
               eval="[(4, ref('group_service_request_team_lead'))]"/>

    </record>

    <!-- Employee: Own Requests Only -->

    <record id="rule_service_request_employee"
            model="ir.rule">

        <field name="name">
            Employee Own Requests
        </field>

        <field name="model_id"
               ref="model_service_request"/>

        <field name="groups"
               eval="[(4, ref('group_service_request_employee'))]"/>

        <field name="domain_force">
            [('create_uid', '=', user.id)]
        </field>

    </record>

    <record id="rule_service_request_team_lead"
            model="ir.rule">

        <field name="name">
            Team Lead All Requests
        </field>

        <field name="model_id"
               ref="model_service_request"/>

        <field name="groups"
               eval="[(4, ref('group_service_request_team_lead'))]"/>

        <field name="domain_force">
            [(1, '=', 1)]
        </field>

    </record>


    <record id="rule_service_request_manager"
            model="ir.rule">

        <field name="name">
            Manager Full Access
        </field>

        <field name="model_id"
               ref="model_service_request"/>

        <field name="groups"
               eval="[(4, ref('group_service_request_manager'))]"/>

        <field name="domain_force">
            [(1, '=', 1)]
        </field>

    </record>

</odoo>